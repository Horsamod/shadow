<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <com.horsa.shadowlib.CssShadowLayout
        android:id="@+id/my_shadow_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:shadowBlur="15dp"
        app:shadowColor="#4D000000"
        app:shadowCornerRadius="16dp"
        app:shadowFillColor="#ffffff"
        app:shadowOffsetX="0dp"
        app:shadowOffsetY="10dp"
        app:shadowSpread="2dp">

        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CSS Shadow Card"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Exact control over blur, spread, color, and offset."
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="14sp" />

        </LinearLayout>

    </com.horsa.shadowlib.CssShadowLayout>

</LinearLayout>
